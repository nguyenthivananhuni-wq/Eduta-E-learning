# Database — SQLite local
DATABASE_URL="file:./dev.db"

# Auth.js v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_STRING"
NEXTAUTH_URL="http://localhost:3000"

# App
ADMIN_EMAIL="admin@eduta.local"

# AI Recommendation (Phase 09) — OPTIONAL.
# Lấy key tại https://console.anthropic.com (có $5 credit free khi đăng ký).
# Bỏ trống → tự động fallback rule-based, KHÔNG cần restart.
ANTHROPIC_API_KEY=""

# Production (Turso) — only set in Vercel env, not locally
# DATABASE_URL="libsql://your-db.turso.io?authToken=xxx"
# TURSO_AUTH_TOKEN="xxx"
